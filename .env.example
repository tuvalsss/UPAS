# ── Secrets & credentials ────────────────────────────────────
.env
config/kalshi_private_key.pem

# Polymarket
POLY_GAMMA_BASE=https://gamma-api.polymarket.com
POLY_CLOB_BASE=https://clob.polymarket.com
POLY_CLOB_WS=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLY_API_KEY=YOUR_POLY_API_KEY
POLY_SECRET=YOUR_POLY_SECRET
POLY_PASSPHRASE=YOUR_POLY_PASSPHRASE
POLY_PRIVATE_KEY=YOUR_POLY_PRIVATE_KEY
POLY_BUILDER_API_KEY=YOUR_BUILDER_KEY
POLY_BUILDER_SECRET=YOUR_BUILDER_SECRET
POLY_BUILDER_PASSPHRASE=YOUR_BUILDER_PASSPHRASE

# Kalshi
KALSHI_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=YOUR_KALSHI_KEY_ID
KALSHI_PRIVATE_KEY_PATH=config/kalshi_private_key.pem

# Anthropic / Claude
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY
ANTHROPIC_MODEL_STANDARD=claude-sonnet-4-6
ANTHROPIC_MODEL_COMPLEX=claude-opus-4-7
# "user" = claude CLI login (saves credits), "api" = API key
CLAUDE_AUTH_MODE=user

# Telegram Alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Local LLM fallback (Ollama) — used when Claude API fails or LLM_LOCAL_ONLY=1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct        # primary (B tier) — 4.7GB, best 7B for JSON
OLLAMA_FAST_MODEL=phi3:mini             # C tier / bulk scoring — 2.2GB, fastest
OLLAMA_TIMEOUT_SEC=30
LLM_LOCAL_ONLY=0                        # 1 = never call Claude, local only

# App
LOG_LEVEL=INFO
DATABASE_PATH=data/upas.db
CHECKPOINT_PATH=data/checkpoints
